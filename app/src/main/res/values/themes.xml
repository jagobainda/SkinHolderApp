<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SkinHolderApp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Surface & Background -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorSurfaceContainerLowest">@color/surface_container_lowest</item>
        <item name="colorSurfaceContainerLow">@color/surface_container_low</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/surface_container_highest</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Card style: force neutral gray background, no green elevation tint -->
        <item name="materialCardViewStyle">@style/Widget.SkinHolder.Card</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>

        <!-- Force dark appearance in both modes -->
        <item name="android:forceDarkAllowed">false</item>

        <!-- Bottom Navigation styling -->
        <item name="bottomNavigationStyle">@style/Widget.SkinHolder.BottomNavigation</item>

        <!-- Snackbar styling -->
        <item name="snackbarStyle">@style/Widget.SkinHolder.Snackbar</item>
    </style>

    <style name="Theme.SkinHolderApp.Splash" parent="Theme.SkinHolderApp">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Widget.SkinHolder.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bar</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SkinHolder.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.SkinHolder.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
    </style>

    <style name="Widget.SkinHolder.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/surface_container</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.SkinHolder.Snackbar</item>
    </style>

    <style name="ThemeOverlay.SkinHolder.Snackbar" parent="">
        <item name="colorOnSurface">@color/on_surface</item>
    </style>

    <!-- Card: neutral gray background, no M3 primary color tint from elevation -->
    <style name="Widget.SkinHolder.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_container</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>